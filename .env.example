# Fishing Forecast — environment variables
#
# Nothing here is required to run the app: Open-Meteo (forecast + marine) is
# free and keyless, and is the real, working primary data source in v1.
# The variables below are extension points — set one and its matching
# adapter (currently a documented stub that returns null) takes over from
# Open-Meteo automatically. No code changes needed, just restart/redeploy.

# ECMWF (European Centre for Medium-Range Weather Forecasts) — global weather, paid.
# Adapter: src/services/weather/officialAdapters.ts (ecmwfAdapter)
ECMWF_API_KEY=

# NOAA (US National Oceanic and Atmospheric Administration) — weather, free w/ registration.
# Adapter: src/services/weather/officialAdapters.ts (noaaAdapter)
NOAA_API_KEY=

# KNMI (Koninklijk Nederlands Meteorologisch Instituut) — best weather source for Zaandam/NL.
# Adapter: src/services/weather/officialAdapters.ts (knmiAdapter)
KNMI_API_KEY=

# INMET (Instituto Nacional de Meteorologia) — best weather source for Guaratuba/Curitiba, Brazil.
# Adapter: src/services/weather/officialAdapters.ts (inmetAdapter)
INMET_API_KEY=

# Stormglass.io — dedicated tide-gauge API, global coverage, free tier available.
# Adapter: src/services/tide/officialAdapters.ts (stormglassAdapter)
STORMGLASS_API_KEY=

# WorldTides.info — dedicated tide predictions API, paid.
# Adapter: src/services/tide/officialAdapters.ts (worldTidesAdapter)
WORLDTIDES_API_KEY=
